generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// In Prisma v7: connection URLs live in prisma.config.ts, NOT here.
// The datasource block only needs the provider.
datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("CUSTOMER") // "ADMIN" | "CUSTOMER"
  
  // New fields
  nationalId String?
  phoneNumber String?
  image      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases         Case[]
  notifications Notification[]
}

model Case {
  id             String   @id @default(uuid())
  title          String
  description    String
  status         String   @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED" | "REJECTED"
  documentType   String?
  plaintiffName  String?
  plaintiffPhone String?
  plaintiffAddress String?
  defendantName  String?
  defendantPhone String?
  defendantAddress String?
  amount         Float?
  defendantType  String?  // "INDIVIDUAL" | "CORPORATE"
  adminNotes     String?

  // New advanced fields
  noticeType     String?  // "RENT", "DEBT", "CONTRACT", "GENERAL"
  deadlineDays   Int      @default(15)
  trackingNumber String?
  referenceNumber String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  files     CaseFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Notification {
  id        String   @id @default(uuid())
  userId    String?  // If null, it's a system-wide or admin-targeted notification
  user      User?    @relation(fields: [userId], references: [id])
  message   String
  type      String   @default("INFO") // "INFO" | "SUCCESS" | "WARNING" | "ERROR"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CaseFile {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileType  String?
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  createdAt DateTime @default(now())
}

